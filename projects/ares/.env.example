# ARES — variabili d'ambiente. Copia questo file in .env e compila.

# Firebase (collections nexo_*)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# COSMINA (project Firebase reale, non l'alias acg-clima-service)
COSMINA_PROJECT_ID=garbymobile-f89ac

# GRAPH API per generazione RTI (PDF da template)
GRAPH_API_URL=https://graph-acg.web.app/api/v1/generate
GRAPH_API_KEY=

# ─── Guardie ARES (sicurezza scritture su COSMINA) ───
# Pattern uguale a ECHO. Le LETTURE (interventiAperti) sono SEMPRE attive.
# Le SCRITTURE (apriIntervento) richiedono DUE strati di guardia.

# DRY-RUN: di default ON. apriIntervento NON scrive su
# cosmina_interventi_pianificati, ritorna intervento finto con id
# `dryrun_*` e mirror su nexo_hub `ares_interventi` (per debug).
ARES_DRY_RUN=true

# Whitelist tipi intervento (CSV). Se vuoto → tutti ammessi (USE WITH CARE).
# Esempio prudente: solo manutenzioni programmate.
# ARES_ALLOWED_TIPI=manutenzione
ARES_ALLOWED_TIPI=
