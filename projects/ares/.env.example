# ARES — variabili d'ambiente. Copia questo file in .env e compila.

# Firebase (collections nexo_*)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# COSMINA (collections operative del CRM esistente)
COSMINA_PROJECT_ID=acg-clima-service

# GRAPH API per generazione RTI (PDF da template)
GRAPH_API_URL=https://graph-acg.web.app/api/v1/generate
GRAPH_API_KEY=

# Modalità sicura: se true, ogni write su COSMINA viene loggato ma NON eseguito.
# Mettere false solo dopo verifica end-to-end.
DRY_RUN=false
