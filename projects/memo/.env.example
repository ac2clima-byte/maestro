# MEMO — variabili d'ambiente. Copia in .env e compila.

# Firebase (nexo + progetti COSMINA / Guazzotti per lettura dati operativi)
FIREBASE_PROJECT_ID=nexo-hub-15f2d
COSMINA_PROJECT_ID=acg-clima-service
GUAZZOTTI_PROJECT_ID=guazzotti-tec

# Dischi di rete (lettura sola, accesso via WSL /mnt/)
DISCO_N_PATH=/mnt/n
DISCO_I_PATH=/mnt/i
DISCO_L_PATH=/mnt/l
DISCO_M_PATH=/mnt/m

# Modalità sicura: se true, `nuovoCliente` non scrive su crm_clienti.
DRY_RUN=false
