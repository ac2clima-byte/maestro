# CHRONOS — variabili d'ambiente. Copia in .env e compila.

# Firebase (collections nexo_*)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# COSMINA (lettura impianti / scadenze)
COSMINA_PROJECT_ID=acg-clima-service

# Default per ottimizzazione giornata
ORE_LAVORATIVE_GIORNO=8

# Modalità sicura: se true, prenotazioni/riprogrammazioni NON vengono persistite.
DRY_RUN=false
