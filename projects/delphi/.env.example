# DELPHI — variabili d'ambiente. Copia in .env e compila.

# Firebase (collections nexo_*)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# COSMINA + Guazzotti (lettura dati operativi e finanziari)
COSMINA_PROJECT_ID=acg-clima-service
GUAZZOTTI_PROJECT_ID=guazzotti-tec

# Diogene (FastAPI + Postgres su Railway) — backend analitico esistente
DIOGENE_API_URL=
DIOGENE_API_TOKEN=

# Anthropic (Sonnet per analisi complesse + tool calling)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-5

# Modalità sicura: irrilevante per DELPHI (read-only), rispettata per uniformità.
DRY_RUN=false
