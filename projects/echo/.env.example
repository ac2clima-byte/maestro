# ECHO — variabili d'ambiente. Copia questo file in .env e compila.

# Firebase (condiviso con tutti i Colleghi NEXO)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# WhatsApp via Waha (self-hosted)
# Lasciare VUOTI per leggere automaticamente da Firestore
# cosmina_config/whatsapp (URL, secret, session) — pattern già in uso da
# COSMINA Inbox. Riempire qui solo per dev locale isolato.
WAHA_API_URL=
WAHA_API_KEY=
WAHA_SESSION=default
WAHA_ENABLED=true

# Multi-progetto Firebase
COSMINA_PROJECT_ID=garbymobile-f89ac

# ─── Guardie ECHO (sicurezza invii) ───
# DRY-RUN: di default ON. ECHO scrive `echo_messages` con status="skipped"
# e NON chiama Waha. Disattivare SOLO quando si vuole davvero spedire.
ECHO_DRY_RUN=true

# Whitelist destinatari WhatsApp (CSV, formato +39...). Se VUOTA → tutti
# ammessi (USE WITH CARE). Default: solo numeri esplicitamente listati.
# ECHO_ALLOWED_NUMBERS=+393331234567,+393339876543
ECHO_ALLOWED_NUMBERS=

# Numero del destinatario test (usato dallo script test-send-wa.js)
# ECHO_TEST_PHONE=+39...
ECHO_TEST_PHONE=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_ALBERTO=

# Exchange (per invio email — pattern stesso di IRIS)
EWS_URL=https://remote.gruppobadano.it/ews/exchange.asmx
EWS_USERNAME=
EWS_PASSWORD=

# Voce (binari riusati da HERMES, path opzionale)
EDGE_TTS_BIN=
WHISPER_BIN=

# Modalità sicura: se true, ogni send viene loggato ma NON eseguito.
# Mettere false solo dopo verifica end-to-end.
DRY_RUN=false
