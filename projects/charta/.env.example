# CHARTA — variabili d'ambiente. Copia in .env e compila.

# Firebase (collections nexo_*)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# COSMINA (anagrafica clienti)
COSMINA_PROJECT_ID=acg-clima-service

# Guazzotti TEC (pagamenti clienti, commesse)
GUAZZOTTI_PROJECT_ID=guazzotti-tec

# Fatture in Cloud (SaaS) — API key per lettura/scrittura
FATTURE_IN_CLOUD_API_KEY=
FATTURE_IN_CLOUD_COMPANY_ID=

# Modalità sicura: se true, scritture e solleciti vengono loggati ma NON eseguiti.
DRY_RUN=false
