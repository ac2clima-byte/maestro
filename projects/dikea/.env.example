# DIKEA — variabili d'ambiente. Copia in .env e compila.

# Firebase (collections nexo_*)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# COSMINA (impianti CIT, audit_log, gdpr_consents)
COSMINA_PROJECT_ID=acg-clima-service

# Portale CURIT Piemonte (usato dal worker Python)
CURIT_USERNAME=
CURIT_PASSWORD=

# Anthropic (modello Sonnet per precisione critica)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-5

# Modalità sicura: se true, invio DiCo / bozze PEC NON vengono emesse.
DRY_RUN=false
