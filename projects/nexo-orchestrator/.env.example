# NEXO Orchestrator — variabili d'ambiente. Copia in .env e compila.

# Firebase (condiviso con tutti i Colleghi)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# Anthropic (Haiku per routing veloce)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5

# Timeout pending (minuti) — oltre questa soglia un messaggio viene escalato
PENDING_TIMEOUT_MINUTES=30

# Canale ECHO per escalation
ESCALATION_CHANNEL=whatsapp

# Modalità sicura: se true, rewrite Lavagna e workflow NON vengono eseguiti.
DRY_RUN=false
