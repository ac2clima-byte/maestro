# EMPORION — variabili d'ambiente. Copia in .env e compila.

# Firebase (collections nexo_*)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# COSMINA (anagrafica magazzino, listini, OCR)
COSMINA_PROJECT_ID=acg-clima-service

# Magazzino Pro (Flask/SQLite, opzionale)
MAGAZZINO_PRO_URL=
MAGAZZINO_PRO_TOKEN=

# Modalità sicura: se true, movimenti/ordini vengono loggati ma NON eseguiti.
DRY_RUN=false
