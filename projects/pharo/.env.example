# PHARO — variabili d'ambiente. Copia in .env e compila.

# Firebase (collections nexo_*)
FIREBASE_PROJECT_ID=nexo-hub-15f2d

# COSMINA (lettura cross-progetto per check)
COSMINA_PROJECT_ID=acg-clima-service

# Budget Anthropic mensile (EUR) — alert a 50% / 90%
ANTHROPIC_BUDGET_MONTHLY=50

# Intervallo di esecuzione dei check periodici (secondi)
HEARTBEAT_INTERVAL_SECONDS=300

# Modalità sicura: se true, alert vengono loggati ma NON persistiti.
DRY_RUN=false
