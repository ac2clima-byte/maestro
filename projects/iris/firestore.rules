rules_version = '2';

// IRIS / NEXO v0.2 — rules con gate auth applicato a livello UI + API.
//
// Modello sicurezza:
//  · La PWA NEXO richiede login ACG Suite (Firebase Auth garbymobile-f89ac).
//  · Le Cloud Function (nexusRouter, pharoRtiDashboard, pharoResolveAlert)
//    verificano l'ID Token via admin.auth().verifyIdToken() prima di
//    rispondere (401 altrimenti).
//  · Le scritture Firestore passano SEMPRE via Cloud Function (Admin SDK),
//    quindi le write sono già bloccate lato client.
//  · Le letture restano pubbliche: (a) l'utente ha già superato il gate UI;
//    (b) i dati sono metadati aggregati (counts, stati, alert), non PII;
//    (c) auth-required su nexo-hub-15f2d non funzionerebbe con token emessi
//    da garbymobile-f89ac (progetto diverso).
service cloud.firestore {
  match /databases/{database}/documents {
    // iris_emails: lettura pubblica in v0.1 per la PWA senza login.
    // La scrittura resta bloccata a client; scrive solo il backend via Admin SDK.
    match /iris_emails/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // iris_corrections: blocca lettura/scrittura client in v0.1.
    match /iris_corrections/{docId} {
      allow read, write: if false;
    }

    // iris_threads: stessa policy di iris_emails (read pubblico per la PWA,
    // write riservato al backend via Admin SDK).
    match /iris_threads/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // iris_sender_profiles: stessa policy (read pubblico per la PWA,
    // write riservato al backend via Admin SDK).
    match /iris_sender_profiles/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // iris_watchlist: in v0.1 (no auth) la PWA scrive direttamente. Validiamo
    // i campi minimi e limitiamo dimensione per evitare abuso.
    // TODO (v0.2): require request.auth != null e legare a userId.
    match /iris_watchlist/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 320 &&
        (request.resource.data.motivo == null || request.resource.data.motivo is string) &&
        (request.resource.data.nota == null || request.resource.data.nota is string) &&
        (!('motivo' in request.resource.data) || request.resource.data.motivo.size() <= 80) &&
        (!('nota' in request.resource.data) || request.resource.data.nota.size() <= 1000);
      allow delete: if true;
    }

    // iris_rate_suggest_reply: counter rate-limit della Cloud Function
    // suggestReply. Solo backend (Admin SDK) può accedere.
    match /iris_rate_suggest_reply/{docId} {
      allow read, write: if false;
    }

    // iris_rules: regole declarative del RuleEngine.
    // Read pubblico (la PWA mostra l'elenco). Create/delete solo Admin SDK
    // (le regole vengono seed-ate dallo script seed_rules.py).
    // Update consentito al client SOLO se modifica unicamente il campo
    // `enabled` (toggle on/off dalla PWA in /settings/regole).
    match /iris_rules/{ruleId} {
      allow read: if true;
      allow create, delete: if false;
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enabled', 'updatedAt']) &&
        request.resource.data.enabled is bool;
    }

    // nexo_dev_requests: dev requests scritte dalla PWA (in-app feedback
    // / "build IRIS from IRIS"). Shape standard:
    //   { description: string, status: "pending",
    //     emailRef: { id, sender, subject, category }? | null,
    //     createdAt: timestamp }
    // v0.1 no-auth: client può create + read; update/delete solo Admin SDK.
    // TODO (v0.2): require request.auth != null.
    match /nexo_dev_requests/{docId} {
      allow read: if true;
      allow create: if
        request.resource.data.description is string &&
        request.resource.data.description.size() > 0 &&
        request.resource.data.description.size() <= 4000 &&
        request.resource.data.status == "pending" &&
        (!('emailRef' in request.resource.data) ||
           request.resource.data.emailRef == null ||
           (
             request.resource.data.emailRef is map &&
             (!('id' in request.resource.data.emailRef) || request.resource.data.emailRef.id.size() <= 200) &&
             (!('sender' in request.resource.data.emailRef) || request.resource.data.emailRef.sender.size() <= 320) &&
             (!('subject' in request.resource.data.emailRef) || request.resource.data.emailRef.subject.size() <= 500) &&
             (!('category' in request.resource.data.emailRef) || request.resource.data.emailRef.category.size() <= 60)
           ));
      allow update, delete: if false;
    }

    // ─── Collections NEXO (Lavagna + altri Colleghi) ──────────────
    // Read pubblica per la PWA (dashboard "Stato Lavagna", "Alert
    // PHARO", ecc.). Write riservata al backend (Admin SDK) in v0.1.

    match /nexo_lavagna/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /pharo_alerts/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /pharo_heartbeat/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /pharo_checks/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /pharo_budget/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // echo_notifications: la PWA le mostra come stand-in per gli alert
    // PHARO finché PHARO non è attivo.
    match /echo_notifications/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // nexo_budget: la PWA potrebbe mostrare lo stato consumi.
    match /nexo_budget/{docId=**} {
      allow read: if true;
      allow write: if false;
    }

    // nexo_logs: lettura diagnostica (nessun dato sensibile in v0.1).
    match /nexo_logs/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // NEXUS chat — storico conversazioni e sessioni.
    // Read pubblico per la PWA (la chat si aggiorna via onSnapshot).
    // Write SOLO Admin SDK (via Cloud Function `nexusRouter`), così:
    //  · la API key Anthropic non è mai nel browser
    //  · nessuno può iniettare messaggi "assistant" falsi
    //  · rate limiting centralizzato nella function
    match /nexus_chat/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /nexus_sessions/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Rate limit counter NEXUS, solo backend.
    match /iris_rate_nexus/{docId} {
      allow read, write: if false;
    }

    // ECHO messaggi inviati — read pubblico per la pagina ECHO della PWA,
    // write SOLO Admin SDK (Cloud Function che chiama Waha/Telegram).
    match /echo_messages/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /echo_notifications/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // CALLIOPE bozze — read pubblico per la pagina CALLIOPE della PWA,
    // write SOLO Admin SDK (la bozza è generata via Claude Sonnet lato server).
    match /calliope_bozze/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /calliope_template/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ARES interventi — mirror audit su nexo-hub (scritto da handleAresApriIntervento).
    // Read pubblica per dashboard ARES della PWA, write solo Admin SDK.
    match /ares_interventi/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /ares_assegnazioni/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // CHARTA — registrazione incassi (mirror su nexo-hub).
    match /charta_pagamenti/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ECHO — log digest mattutino.
    match /echo_digest_log/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Orchestrator — log workflow multi-step (guasto_urgente, ecc.).
    match /nexo_orchestrator_log/{flowId} {
      allow read: if true;
      allow write: if false;
      match /steps/{stepId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // IRIS poller state (watermark + stats run).
    match /iris_poller_state/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // PHARO health snapshots (storico scheduler pharoHealthCheck).
    match /pharo_health_snapshots/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // nexo_config/fcm_tokens: mappa userKey → { token, userAgent, updatedAt }.
    // Lettura libera (nessun PII, token FCM opachi). Scrittura SOLO da client
    // autenticato (Auth ACG), e SOLO sui propri campi (userKey == email sanitizzata).
    //
    // Nota: l'Auth ACG è su progetto garbymobile-f89ac (SSO cross-project),
    // quindi request.auth qui non scatterebbe per gli ID Token ACG. Per questo
    // tutte le scritture "importanti" passano da Cloud Function (Admin SDK).
    // Per i token FCM accettiamo solo merge del singolo campo utente,
    // validando shape e dimensioni per bloccare abusi massivi.
    match /nexo_config/fcm_tokens {
      allow read: if true;
      // Scrittura accettata solo se il diff modifica ESATTAMENTE una chiave
      // (il campo userKey dello scrivente) con un oggetto ben formato.
      allow update, create: if
        request.resource.data.diff(resource.data != null ? resource.data : {}).affectedKeys().size() == 1 &&
        request.resource.data.keys().size() <= 50;
      allow delete: if false;
    }
    // Default per altri doc in nexo_config: solo backend.
    match /nexo_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // nexo_push_log: audit log invii push (Admin SDK only).
    match /nexo_push_log/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // iris_patterns: training via NEXUS chat ("analizza email" + conferma utente).
    // Read pubblico per la PWA (pagina training in futuro); write SOLO Admin SDK
    // via Cloud Function (rate-limited, rinforzato dalla pipeline di addestramento).
    match /iris_patterns/{patternId} {
      allow read: if true;
      allow write: if false;
    }

    // iris_patterns_stats: counter per confidenza cumulativa.
    match /iris_patterns_stats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // iris_archive_queue: coda richieste archivio email verso EWS
    // (eseguite dallo script su Hetzner). Solo Admin SDK può scrivere.
    match /iris_archive_queue/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // nexus_audio_transcripts: trascrizioni chiamate + analisi Haiku
    // (upload audio da NEXUS chat). Solo Admin SDK scrive.
    match /nexus_audio_transcripts/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // nexus_tts_cache: cache audio MP3 generati da edge-tts.
    // Read interno solo (l'audio è servito via Cloud Function).
    // Write Admin SDK only.
    match /nexus_tts_cache/{docId} {
      allow read, write: if false;
    }

    // charta_preventivi: registro preventivi generati (bozze + inviati).
    // Read pubblico per dashboard CALLIOPE/CHARTA, write Admin SDK only.
    match /charta_preventivi/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // memo_aziende: cache arricchimento dati aziende (per P.IVA).
    // Read pubblico, write Admin SDK only.
    match /memo_aziende/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // memo_clienti_cache: cache completa clienti COSMINA (scan + refresh).
    // Read pubblico (PWA dashboard MEMO), write Admin SDK only.
    match /memo_clienti_cache/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // nexo_dev_requests_queue: coda letta dal poller locale dev_request_poller.mjs
    // (gira in WSL accanto a MAESTRO). Scritta dalla Cloud Function nexusRouter
    // via Admin SDK. Read pubblica per debug, write riservata al backend.
    match /nexo_dev_requests_queue/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // nexo_code_status: stato in tempo reale di MAESTRO + Claude Code,
    // letto da Claude Chat per sapere cosa sta succedendo in remoto.
    // Read pubblico (no auth) e write pubblica perché MAESTRO gira in WSL
    // e scrive con Application Default Credentials senza ID Token. I dati
    // sono solo metadati di stato (fase, taskId, msg) — nessun PII.
    match /nexo_code_status/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Default deny per ogni altra collection.
    // Quando aggiungi un Collega con nuova collection, aggiungi la rule qui sopra.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
