{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "*.log",
        ".env"
      ]
    }
  ],
  "hosting": {
    "public": "pwa",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "screenshots/**"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
