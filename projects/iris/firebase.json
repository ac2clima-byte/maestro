{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "pwa",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "screenshots/**"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
